{
  "name": "@scalius/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.local.jsonc --local --port 8787 --persist-to ${SCALIUS_WRANGLER_STATE:-../../.wrangler/state} --show-interactive-dev-session=false",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "node ../../scripts/deploy.mjs --only api",
    "typecheck": "tsc --noEmit",
    "db:generate": "cd ../../packages/database && drizzle-kit generate --config drizzle.config.ts",
    "db:migrate:local": "node ../../scripts/deploy.mjs --migrate-only --local",
    "db:migrate:remote": "node ../../scripts/deploy.mjs --migrate-only",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.18",
    "@ai-sdk/openai": "^4.0.16",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.9.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@polar-sh/sdk": "^0.48.1",
    "@scalius/core": "workspace:*",
    "@scalius/database": "workspace:*",
    "@scalius/shared": "workspace:*",
    "agents": "^0.17.4",
    "ai": "7.0.31",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.18",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "firebase": "^12.14.0",
    "hono": "^4.12.25",
    "jsonwebtoken": "^9.0.3",
    "mimetext": "^3.0.28",
    "nanoid": "^6.0.0",
    "standardwebhooks": "^1.0.0",
    "stripe": "^22.2.1",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@scalius/tsconfig": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
