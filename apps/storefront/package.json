{
  "name": "@scalius/storefront",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --host --port 4322",
    "start": "node ./dist/server/entry.mjs",
    "build": "node scripts/generate-build-id.js && astro check && astro build && node ../../scripts/clean-dist-env-files.mjs apps/storefront",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "node ../../scripts/deploy.mjs --only storefront",
    "typecheck": "node scripts/generate-build-id.js && astro check",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^5.0.7",
    "@nanostores/react": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@scalius/api-client": "workspace:*",
    "@scalius/shared": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.18.0",
    "nanoid": "^6.0.0",
    "nanostores": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-phone-number-input": "^3.4.17",
    "sharp": "^0.35.1",
    "simple-icons": "^16.23.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@cloudflare/workers-types": "^4.20260613.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "happy-dom": "^20.10.3",
