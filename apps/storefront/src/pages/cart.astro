---
// src/pages/cart.astro
import Layout from "@/layouts/Layout.astro";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import LocationSelector from "@/components/LocationSelector";
import ShippingLocationSelector from "@/components/ShippingLocationSelector";
import PhoneField from "@/components/PhoneField";
import { getCities, processOrder } from "@/lib/cart/server";
import {
  getShippingMethods,
  getLayoutData,
  type ShippingMethod,
  getActiveCheckoutLanguage,
  type CheckoutLanguageData,
  getCheckoutConfig,
  isCodOnly,
} from "@/lib/api";
import { getCustomerSessionTokenFromCookie } from "@/lib/customer-session-cookie";

// Parallel fetch: layout + cities + shipping methods + checkout language + checkout config
const [
  layoutData,
  cities,
  shippingMethodsResponse,
  checkoutLanguageResponse,
  checkoutConfig,
] = await Promise.all([
  getLayoutData(),
  getCities(),
  getShippingMethods(),
  getActiveCheckoutLanguage(),
  getCheckoutConfig(),
]);
const shippingMethods: ShippingMethod[] = shippingMethodsResponse || [];
const checkoutUnavailable =
  checkoutConfig.unavailable === true ||
  checkoutConfig.gateways.length === 0 ||
  shippingMethods.length === 0 ||
  cities.length === 0;
const checkoutUnavailableMessage =
  checkoutConfig.unavailableMessage || "Checkout is temporarily unavailable. Please try again shortly.";
const codOnly = !checkoutUnavailable && isCodOnly(checkoutConfig);
const allowedCountriesMode = checkoutConfig?.allowedCountriesMode || "include";
const lang: CheckoutLanguageData = checkoutLanguageResponse || {
  id: "fallback",
  name: "English (Fallback)",
  code: "en",
  languageData: {
    pageTitle: "Cart & Checkout",
    checkoutSectionTitle: "Checkout Information",
    cartSectionTitle: "Shopping Cart",
    customerNameLabel: "Full Name",
    customerNamePlaceholder: "Enter your full name",
    customerPhoneLabel: "Phone Number",
    customerPhonePlaceholder: "Phone number",
    customerPhoneHelp: "Enter your phone number with country code",
    customerEmailLabel: "Email (Optional)",
    customerEmailPlaceholder: "Enter your email address",
    shippingAddressLabel: "Delivery Address",
    shippingAddressPlaceholder: "Enter your full delivery address",
    cityLabel: "City",
    zoneLabel: "Zone",
    areaLabel: "Area (Optional)",
    shippingMethodLabel: "Choose Delivery Option",
    orderNotesLabel: "Order Notes (Optional)",
    orderNotesPlaceholder: "Any special instructions for your order?",
    continueShoppingText: "Continue Shopping",
    subtotalText: "Subtotal",
    shippingText: "Shipping",
    discountText: "Discount",
    totalText: "Total",
    discountCodePlaceholder: "Discount code",
    applyDiscountText: "Apply",
    removeDiscountText: "Remove",
    placeOrderText: "Place Order",
    processingText: "Processing...",
    emptyCartText: "Your cart is empty",
    termsText:
      "By placing this order, you agree to our Terms of Service and Privacy Policy",
    processingOrderTitle: "Processing Your Order",
    processingOrderMessage: "Please wait while we process your order.",
    requiredFieldIndicator: "*",
  },
  fieldVisibility: {
    showEmailField: true,
    showOrderNotesField: true,
    showAreaField: true,
  },
  isActive: true,
  isDefault: true,
};

// Initialize error message and success state
let errorMessage = "";
let successOrderId = "";
let isProcessing = false;

// Handle form submission — only for COD-only flow.
// When multiple gateways are active, the form is intercepted client-side
// and the user is redirected to /checkout for payment selection.
if (Astro.request.method === "POST" && codOnly) {
  try {
    isProcessing = true;
    const formData = await Astro.request.formData();

    // Check if cart is empty
    const cartItems = formData.get("cartItems") as string;
    if (!cartItems || cartItems === "{}" || cartItems === "[]") {
      throw new Error(
        "Your cart is empty. Please add items to your cart before placing an order."
      );
    }

    const result = await processOrder(formData, {
      customerSessionToken: getCustomerSessionTokenFromCookie(
        Astro.request.headers.get("cookie"),
      ),
    });

    if (
      result.success &&
      "orderId" in result &&
      "receiptToken" in result &&
      result.orderId &&
      result.receiptToken
    ) {
      successOrderId = result.orderId;
      return Astro.redirect(
        `/order-success?orderId=${encodeURIComponent(result.orderId)}&token=${encodeURIComponent(result.receiptToken)}`,
      );
    } else {
      console.error("Order processing failed:", result.error);
      const resultError = result.error;
      errorMessage =
        (typeof resultError === "string" ? resultError : resultError?.message) ||
        "Failed to process order. Please try again.";
    }
  } catch (error: unknown) {
    console.error("Order creation failed:", error);
    errorMessage =
      error instanceof Error ? error.message : "An unexpected error occurred";
  } finally {
    isProcessing = false;
  }
}

// Determine submit button label
const submitLabel = codOnly
  ? lang.languageData.placeOrderText
  : checkoutUnavailable
    ? "Checkout temporarily unavailable"
  : "Proceed to Payment →";
---

<Layout title={lang.languageData.pageTitle} layoutData={layoutData} noindex>
  <!-- Hidden checkout meta for client-side JS -->
  <div
    id="checkout-meta"
    data-cod-only={codOnly ? "true" : "false"}
    data-checkout-unavailable={checkoutUnavailable ? "true" : "false"}
    data-checkout-unavailable-message={checkoutUnavailableMessage}
    data-gateways={JSON.stringify(checkoutConfig.gateways)}
    data-guest-checkout-enabled={checkoutConfig.guestCheckoutEnabled !== false ? "true" : "false"}
    data-default-shipping-id={shippingMethods[0]?.id || ""}
    data-default-shipping-fee={String(shippingMethods[0]?.fee ?? 0)}
    hidden
  ></div>

  <main
    class="container max-w-6xl mx-auto px-2 pt-2 pb-3 sm:px-3 sm:pt-2 sm:pb-3"
  >
    {
      checkoutUnavailable && (
        <div
          class="bg-destructive/10 border border-destructive/20 text-destructive px-3 py-2 sm:px-4 sm:py-3 rounded mb-2 sm:mb-2.5 relative text-xs sm:text-sm"
          role="alert"
        >
          <strong class="font-bold">Checkout unavailable: </strong>
          <span class="block sm:inline">{checkoutUnavailableMessage}</span>
        </div>
      )
    }

    {
      errorMessage && (
        <div
          class="bg-destructive/10 border border-destructive/20 text-destructive px-3 py-2 sm:px-4 sm:py-3 rounded mb-2 sm:mb-2.5 relative text-xs sm:text-sm"
          role="alert"
        >
          <strong class="font-bold">Error: </strong>
          <span class="block sm:inline">{errorMessage}</span>
        </div>
      )
    }

    {
      successOrderId && (
        <div
          class="bg-primary/10 border border-primary/20 text-primary px-3 py-2 sm:px-4 sm:py-3 rounded mb-2 sm:mb-2.5 relative text-xs sm:text-sm"
          role="alert"
        >
          <strong class="font-bold">Success! </strong>
          <span class="block sm:inline">
            Your order has been placed successfully. Order ID: {successOrderId}
          </span>
        </div>
      )
    }

    <div class="flex flex-col lg:flex-row-reverse gap-4 lg:gap-8">
      <!-- Cart Items Section - Right on Desktop -->
      <div
        class="lg:w-5/12 lg:sticky lg:self-start transition-all duration-200 order-2 lg:order-1"
        style="top: calc(var(--header-height, 64px) + 1rem);"
      >
        <div
          class="bg-card rounded-xl border border-border shadow-sm overflow-hidden"
        >
          <div
            class="p-3 sm:p-4 border-b border-border bg-muted/50 flex items-center justify-between"
          >
            <h2 class="text-sm sm:text-base font-bold text-foreground">
              {lang.languageData.cartSectionTitle}
            </h2>
            <a
              href="/"
              class="text-xs font-medium text-muted-foreground hover:text-primary transition-colors"
            >
              {lang.languageData.continueShoppingText}
            </a>
          </div>

          <div
            id="cartValidationMessage"
            class="hidden mx-3 mt-3 rounded-lg border border-destructive/30 bg-destructive/10 px-3 py-2 text-xs font-medium text-destructive sm:mx-4"
            role="alert"
          ></div>

          <div class="divide-y divide-gray-50 p-3 sm:p-4 block" id="cartItems">
            <!-- Cart items will be rendered here by JavaScript -->
          </div>

          <div
            class="bg-muted/50 p-3 sm:p-4 space-y-2 border-t border-border"
          >
            <div class="flex justify-between text-xs sm:text-sm text-muted-foreground">
              <span>{lang.languageData.subtotalText}</span>
              <span id="subtotal" class="font-medium text-foreground">0</span>
            </div>
            <div class="flex justify-between text-xs sm:text-sm text-muted-foreground">
              <span>{lang.languageData.shippingText}</span>
              <span id="shippingCost" class="font-medium text-foreground">0</span
              >
            </div>
            <div
              class="flex justify-between text-xs sm:text-sm text-primary"
              id="discountRow"
            >
              <span class="flex items-center gap-1"
                >{lang.languageData.discountText}
                <span
                  id="appliedDiscountCode"
                  class="font-mono text-xs bg-primary/10 px-1 rounded"
                ></span></span
              >
              <span id="discountAmount" class="font-bold">-0</span>
            </div>

            <div class="pt-2 border-t border-border mt-2">
              <div class="flex justify-between items-baseline">
                <span class="text-sm font-bold text-foreground"
                  >{lang.languageData.totalText}</span
                >
                <span
                  id="total"
                  class="text-lg sm:text-xl font-extrabold text-foreground tracking-tight"
                  >0</span
                >
              </div>
            </div>

            <!-- Discount Code Form -->
            <div class="pt-3 mt-1">
              <form id="discountForm" class="relative">
                <div class="flex gap-2">
                  <input
                    type="text"
                    id="discountCodeInput"
                    placeholder={lang.languageData.discountCodePlaceholder}
                    class="flex-1 px-3 py-1.5 bg-background border border-input rounded-lg text-xs sm:text-sm text-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all uppercase font-mono tracking-wider"
                  />
                  <button
                    type="submit"
                    id="applyDiscountBtn"
                    class="px-3 py-1.5 bg-primary text-primary-foreground text-xs sm:text-sm font-semibold rounded-lg hover:bg-primary/90 transition-colors"
                  >
                    {lang.languageData.applyDiscountText}
                  </button>
                  <button
                    type="button"
                    id="removeDiscountBtn"
                    onclick="window.removeDiscountCode()"
                    class="px-3 py-1.5 bg-destructive/10 text-destructive border border-destructive/20 text-xs sm:text-sm font-semibold rounded-lg hover:bg-destructive/20 transition-colors"
                    style="display: none;"
                  >
                    {lang.languageData.removeDiscountText}
                  </button>
                </div>
                <div
                  id="discountMessage"
                  class="absolute -bottom-5 left-0 text-[10px] sm:text-xs font-medium text-danger truncate max-w-full"
                  style="display: none;"
                >
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="mt-4 text-center">
          <p class="text-[10px] text-muted-foreground">
            Secure Checkout • SSL Encrypted
          </p>
        </div>
      </div>

      <!-- Checkout Form Section - Left on Desktop -->
      <div class="lg:w-7/12 order-1 lg:order-2">

        <!-- Optional customer login trigger -->
        <div class="mb-3">
          <button 
            type="button"
            onclick="window.dispatchEvent(new CustomEvent('open-auth-modal'))"
            class="w-full text-left rounded-lg bg-primary/10 border border-border px-4 py-3 text-sm text-primary hover:bg-primary/20 transition-colors shadow-sm flex items-center justify-between group"
          >
            <span class="flex items-center gap-2">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span class="font-medium">Sign in for faster checkout & order tracking</span>
            </span>
            <span class="text-primary font-bold group-hover:translate-x-0.5 transition-transform">→</span>
          </button>
        </div>

        <div
          class="bg-card rounded-xl border border-border shadow-sm p-3 sm:p-4 mb-3"
        >
          <h2
            class="text-base sm:text-lg font-bold text-foreground mb-3 flex items-center gap-2"
          >
            {lang.languageData.checkoutSectionTitle}
          </h2>

          <form method="POST" class="space-y-3" id="checkoutForm">
            <input type="hidden" name="cartItems" id="cartItemsInput" />
            <input type="hidden" name="checkoutId" id="checkoutIdInput" />
            <input
              type="hidden"
              name="discountCodeHidden"
              id="discountCodeHidden"
            />

            <div class="grid gap-3 sm:grid-cols-2">
              <div>
                <Label
                  htmlFor="customerName"
                  className="mb-1 block text-xs font-semibold text-foreground uppercase tracking-wide"
                >
                  {lang.languageData.customerNameLabel}
                  <span class="text-destructive ml-0.5">*</span>
                </Label>
                <Input
                  type="text"
                  id="customerName"
                  name="customerName"
                  required
                  placeholder={lang.languageData.customerNamePlaceholder}
                  className="h-9 w-full bg-muted border-input rounded-lg focus:bg-background focus:border-primary focus:ring-primary/20 text-sm text-foreground"
                />
              </div>

              <div>
                <PhoneField
                  client:visible
                  name="customerPhone"
                  label={lang.languageData.customerPhoneLabel}
                  placeholder={lang.languageData.customerPhonePlaceholder}
                  helpText={lang.languageData.customerPhoneHelp}
                  required
                  allowedCountries={checkoutConfig.allowedCountries || []}
                  allowedCountriesMode={allowedCountriesMode}
                />
              </div>

              {
                lang.fieldVisibility.showEmailField && (
                  <div class="sm:col-span-2">
                    <Label
                      htmlFor="customerEmail"
                      className="mb-1 block text-xs font-semibold text-foreground uppercase tracking-wide"
                    >
                      {lang.languageData.customerEmailLabel}
                    </Label>
                    <Input
                      type="email"
                      id="customerEmail"
                      name="customerEmail"
                      placeholder={lang.languageData.customerEmailPlaceholder}
                      className="h-9 w-full bg-muted border-input rounded-lg focus:bg-background focus:border-primary focus:ring-primary/20 text-sm text-foreground"
                    />
                  </div>
                )
              }

              <div class="sm:col-span-2">
                <Label
                  htmlFor="shippingAddress"
                  className="mb-1 block text-xs font-semibold text-foreground uppercase tracking-wide"
                >
                  {lang.languageData.shippingAddressLabel}
                  <span class="text-destructive ml-0.5">*</span>
                </Label>
                <Textarea
                  id="shippingAddress"
                  name="shippingAddress"
                  required
                  placeholder={lang.languageData.shippingAddressPlaceholder}
                  rows={2}
                  className="w-full min-h-16 resize-none bg-muted border-input rounded-lg focus:bg-background focus:border-primary focus:ring-primary/20 px-3 py-2 text-sm text-foreground"
                />
              </div>

              <div class="sm:col-span-2 border-t border-border pt-4">
                <div class="space-y-4">
                  <ShippingLocationSelector
                    client:load
                    shippingMethods={shippingMethods}
                    shippingMethodLabel={lang.languageData.shippingMethodLabel}
                  />

                  <div class="relative pt-1">
                    <LocationSelector
                      client:load
                      cities={cities}
                      cityLabel={lang.languageData.cityLabel}
                      zoneLabel={lang.languageData.zoneLabel}
                      areaLabel={lang.languageData.areaLabel}
                      showAreaField={lang.fieldVisibility.showAreaField}
                    />
                  </div>
                </div>
              </div>

              {
                lang.fieldVisibility.showOrderNotesField && (
                  <div class="sm:col-span-2">
                    <Label
                      htmlFor="notes"
                      className="mb-1.5 block text-xs font-semibold text-foreground uppercase tracking-wide"
                    >
                      {lang.languageData.orderNotesLabel}
                    </Label>
                    <Textarea
                      id="notes"
                      name="notes"
                      placeholder={lang.languageData.orderNotesPlaceholder}
                      rows={2}
                      className="w-full min-h-16 resize-none bg-muted border-input rounded-lg focus:bg-background focus:border-primary focus:ring-primary/20 px-3 py-2.5 text-sm text-foreground"
                    />
                  </div>
                )
              }
            </div>

            <div class="pt-4">
              <Button
                type="submit"
                className="w-full bg-primary text-primary-foreground font-bold text-base py-3 sm:py-3.5 rounded-xl shadow-lg hover:bg-primary/90 hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.99] transition-all duration-200 overflow-hidden relative"
                id="submitButton"
                disabled={isProcessing || checkoutUnavailable}
              >
                <span class="relative z-10" id="submitButtonText">
                  {isProcessing ? lang.languageData.processingText : submitLabel}
                </span>
              </Button>

              <p class="text-[10px] text-muted-foreground text-center mt-3">
                {lang.languageData.termsText}
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<!-- Loading overlay -->
<div
  id="loadingOverlay"
  style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.8); z-index: 99999; backdrop-filter: blur(4px);"
>
  <div
    style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 20px; border-radius: 8px; text-align: center; width: 280px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);"
  >
    <div
      style="margin: 0 auto 15px; width: 48px; height: 48px; border: 4px solid #f3f3f3; border-top: 4px solid #000; border-radius: 50%; animation: spin 1s linear infinite;"
    >
    </div>
    <h3 style="margin: 0 0 8px; font-size: 16px; font-weight: bold;">
      {lang.languageData.processingOrderTitle}
    </h3>
    <p style="margin: 0 0 12px; font-size: 13px; color: #666;">
      {lang.languageData.processingOrderMessage}
    </p>
    <div
      style="width: 100%; height: 5px; background: #f3f3f3; border-radius: 2.5px; overflow: hidden;"
    >
      <div
        id="loadingProgressBar"
        style="width: 0%; height: 100%; background: #000; transition: width 0.5s;"
      >
      </div>
    </div>
  </div>
</div>

<script>
  import { initCartFunctionality } from "@/lib/cart/client";
  import { getCustomerSession } from "@/lib/api/customer-auth";
  import { clearCheckoutSession } from "@/lib/checkout/session-state";

  type CustomerAutofillProfile = {
    name?: string | null;
    phone?: string | null;
    email?: string | null;
    address?: string | null;
    city?: string | null;
    cityName?: string | null;
    zone?: string | null;
    zoneName?: string | null;
    area?: string | null;
    areaName?: string | null;
  };

  type CartItemForShipping = {
    freeDelivery?: boolean;
  };

  // Initialize cart functionality
  initCartFunctionality();
  clearCheckoutSession();

  // ── Customer login pre-fill ───────────────────────────────────────────────
  
  // Helper to normalize phone numbers — pass through E.164 or raw value
  const normalizePhone = (phone: string | undefined | null) => {
    if (!phone) return "";
    return phone.trim();
  };

  // Helper to fill basic fields
  const fillBasicCustomerFields = (customer: CustomerAutofillProfile) => {
    if (customer?.name) {
      const el = document.getElementById("customerName") as HTMLInputElement;
      if (el && !el.value) el.value = customer.name;
    }
    if (customer?.phone) {
      // PhoneField is a React component — dispatch custom event to update its state
      const phone = normalizePhone(customer.phone);
      if (phone) {
        window.dispatchEvent(new CustomEvent("phone-prefill", { detail: phone }));
      }
    }
    if (customer?.email) {
      const el = document.getElementById("customerEmail") as HTMLInputElement;
      if (el && !el.value) el.value = customer.email;
    }
    if (customer?.address) {
      const el = document.getElementById("shippingAddress") as HTMLTextAreaElement;
      if (el && !el.value) el.value = customer.address;
    }
  };

  // Helper to auto-select City/Zone dropdowns through LocationSelector's event API.
  const fillLocationDropdowns = (customer: CustomerAutofillProfile) => {
    try {
      if (!customer?.cityName && !customer?.city) return;
      window.dispatchEvent(new CustomEvent("location-prefill", {
        detail: {
          city: customer.city,
          cityName: customer.cityName,
          zone: customer.zone,
          zoneName: customer.zoneName,
          area: customer.area,
          areaName: customer.areaName,
        },
      }));
    } catch(err: unknown) {
      console.error("Cart autofill location err:", err);
    }
  };

  // 1. Initial page load hydration (standalone fetch)
  document.addEventListener("DOMContentLoaded", async () => {
    const isUserLoggedIn = document.cookie.split(";").some((c) => c.trim().startsWith("cs_auth=1"));
    if (isUserLoggedIn || !guestCheckoutEnabled) {
      const session = await getCustomerSession();
      if (session.unavailable) {
        console.warn("Customer session autofill skipped:", session.error || "Account status could not be read.");
        return;
      }
      if (session?.authenticated && session.customer) {
        fillBasicCustomerFields(session.customer);
        fillLocationDropdowns(session.customer);
      }
    }
  });

  // 2. Active login intercept (AuthModal)
  window.addEventListener("customer-login", ((e: CustomEvent<CustomerAutofillProfile>) => {
    const customer = e.detail;
    fillBasicCustomerFields(customer);
    // Modal normally resolves quickly, but schedule location fill slightly later to avoid DOM races
    setTimeout(() => fillLocationDropdowns(customer), 300);
  }) as EventListener);

  // ── Multi-gateway checkout redirect ──
  const meta = document.getElementById("checkout-meta");
  const codOnly = meta?.dataset.codOnly === "true";
  const checkoutUnavailable = meta?.dataset.checkoutUnavailable === "true";
  const checkoutUnavailableMessage =
    meta?.dataset.checkoutUnavailableMessage || "Checkout is temporarily unavailable. Please try again shortly.";
  const guestCheckoutEnabled = meta?.dataset.guestCheckoutEnabled !== "false"; // default true

  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("checkoutForm") as HTMLFormElement;
    const submitButton = document.getElementById("submitButton") as HTMLButtonElement;
    const loadingOverlay = document.getElementById("loadingOverlay") as HTMLElement;
    const progressBar = document.getElementById("loadingProgressBar") as HTMLElement;

    const isCartEmpty = () => {
      const input = document.getElementById("cartItemsInput") as HTMLInputElement;
      return !input?.value || input.value === "{}" || input.value === "[]";
    };

    const readCustomerSessionForCheckout = async () => getCustomerSession();
    const initialSubmitText = submitButton?.textContent || "Place Order";
    let submitAfterCustomerSessionCheck = false;
    let submitAfterCartValidation = false;

    const restoreSubmitButton = () => {
      submitButton.disabled = false;
      submitButton.textContent = initialSubmitText;
    };

    const updateCheckoutButtonState = () => {
      if (submitButton) {
        const empty = isCartEmpty();
        const cartBlocked = window.hasCartValidationIssues?.() === true;
        submitButton.disabled = checkoutUnavailable || empty || cartBlocked;
        if (checkoutUnavailable || empty || cartBlocked) submitButton.classList.add("opacity-50", "cursor-not-allowed");
        else submitButton.classList.remove("opacity-50", "cursor-not-allowed");
        submitButton.title = checkoutUnavailable
          ? checkoutUnavailableMessage
          : empty
            ? "Your cart is empty"
            : cartBlocked
              ? window.getCartBlockedMessage?.() || "Some cart items need attention"
              : "";
      }
    };

    updateCheckoutButtonState();
    window.addEventListener("cart-updated", updateCheckoutButtonState);

    if (!form || !submitButton) return;

    form.addEventListener("submit", async (e) => {
      if (checkoutUnavailable) {
        e.preventDefault();
        alert(checkoutUnavailableMessage);
        return;
      }

      // Guest Checkout Interception
      if (!guestCheckoutEnabled && !submitAfterCustomerSessionCheck) {
        e.preventDefault();
        submitButton.disabled = true;
        submitButton.textContent = "Checking account...";

        const session = await readCustomerSessionForCheckout();
        if (session.unavailable) {
          restoreSubmitButton();
          alert(session.error || "We could not verify your account right now. Please try again.");
          return;
        }

        if (!session.authenticated) {
          restoreSubmitButton();
          window.dispatchEvent(new CustomEvent("open-auth-modal"));
          return;
        }

        if (codOnly) {
          submitAfterCustomerSessionCheck = true;
          form.requestSubmit();
          return;
        }
      }

      if (submitAfterCustomerSessionCheck) {
        submitAfterCustomerSessionCheck = false;
      }

      // Cart empty check
      if (isCartEmpty()) {
        e.preventDefault();
        restoreSubmitButton();
        alert("Your cart is empty. Please add items before placing an order.");
        return;
      }

      if (!submitAfterCartValidation) {
        e.preventDefault();
        submitButton.disabled = true;
        submitButton.textContent = "Checking cart...";
        const cartIsValid = await (window.validateCartSnapshot?.() ?? Promise.resolve(true));
        if (!cartIsValid || window.hasCartValidationIssues?.() === true) {
          restoreSubmitButton();
          alert(window.getCartBlockedMessage?.() || "Please review the highlighted cart items before checkout.");
          return;
        }

        if (codOnly) {
          submitAfterCartValidation = true;
          form.requestSubmit();
          return;
        }
      }

      if (submitAfterCartValidation) {
        submitAfterCartValidation = false;
      }

      // Required fields validation
      const requiredFields = ["customerName", "customerPhone", "shippingAddress", "shippingLocation", "city", "zone"];
      const missing: string[] = [];
      for (const field of requiredFields) {
        const el = document.querySelector(`[name="${field}"]`) as HTMLInputElement | null;
        if (!el?.value?.trim()) missing.push(field);
      }
      if (missing.length > 0) {
        e.preventDefault();
        restoreSubmitButton();
        alert(`Please fill in all required fields: ${missing.join(", ")}`);
        return;
      }

      if (!codOnly) {
        // ── Multi-gateway flow: intercept and redirect to /checkout ──
        e.preventDefault();

        // Collect all form data + cart items into sessionStorage
        const formData = new FormData(form);
        const checkoutData: Record<string, string> = {};
        formData.forEach((value, key) => {
          checkoutData[key] = value as string;
        });

        // Also grab location hidden fields that may not be in formData
        const fields = ["city", "zone", "area", "shippingLocation", "cityName", "zoneName", "areaName"];
        for (const f of fields) {
          const el = document.querySelector(`[name="${f}"]`) as HTMLInputElement | null;
          if (el) checkoutData[f] = el.value;
        }

        // Capture the current shipping fee from the ShippingLocationSelector
        // Fall back to the first shipping method's fee when no selection has been made
        const defaultShippingFee = parseFloat(meta?.dataset.defaultShippingFee || "0");
        const defaultShippingId = meta?.dataset.defaultShippingId || undefined;
        let shippingFee = window.lastShippingEventDetail?.fee ?? defaultShippingFee;
        const shippingMethodId = window.lastShippingEventDetail?.id ?? defaultShippingId;

        // Zero out shipping if any cart item has free delivery
        const cartDataForShipping = JSON.parse(
          (document.getElementById('cartItemsInput') as HTMLInputElement)?.value || '{}'
        ) as Record<string, CartItemForShipping>;
        const hasFreeDeliveryItem = Object.values(cartDataForShipping).some(
          (item) => item.freeDelivery
        );
        if (hasFreeDeliveryItem) shippingFee = 0;

        checkoutData["shippingCharge"] = String(shippingFee);
        if (shippingMethodId) checkoutData["shippingMethodId"] = shippingMethodId;

        try {
          sessionStorage.setItem("scalius_checkout_data", JSON.stringify(checkoutData));
          sessionStorage.setItem("scalius_checkout_gateways", meta?.dataset.gateways || "[]");
        } catch {
          // sessionStorage full — proceed anyway
        }

        submitButton.disabled = true;
        submitButton.textContent = "Redirecting to Payment...";
        
        if (loadingOverlay) {
          const loadingTitle = loadingOverlay.querySelector("h3");
          const loadingMsg = loadingOverlay.querySelector("p");
          if (loadingTitle) loadingTitle.textContent = "Redirecting to Payment";
          if (loadingMsg) loadingMsg.textContent = "Please wait while we load the payment gateway options.";
          loadingOverlay.style.display = "block";
          document.body.style.overflow = "hidden";
        }

        if (progressBar) {
          progressBar.style.width = "0%";
          setTimeout(() => { progressBar.style.width = "40%"; }, 100);
          setTimeout(() => { progressBar.style.width = "80%"; }, 300);
        }

        // Add a slight delay for a smooth visual transition
        setTimeout(() => {
          window.location.href = "/checkout";
        }, 400);
        return;
      }

      // ── COD-only flow: normal form POST ──
      submitButton.disabled = true;
      submitButton.textContent = "Processing...";
      if (loadingOverlay) {
        loadingOverlay.style.display = "block";
        document.body.style.overflow = "hidden";
        window.scrollTo(0, 0);
      }
      if (progressBar) {
        progressBar.style.width = "0%";
        setTimeout(() => { progressBar.style.width = "30%"; }, 300);
        setTimeout(() => { progressBar.style.width = "60%"; }, 1000);
        setTimeout(() => { progressBar.style.width = "80%"; }, 2000);
      }
    });
  });

  // ── Abandoned checkout tracking ───────────────────────────────────────────
  function setupFormListeners() {
    const form = document.getElementById("checkoutForm") as HTMLFormElement;
    if (!form) return;
    form.addEventListener("input", () => {
      window.handleAbandonedCheckout?.();
    });
  }

  document.addEventListener("DOMContentLoaded", setupFormListeners);
  document.addEventListener("astro:page-load", setupFormListeners);
</script>

