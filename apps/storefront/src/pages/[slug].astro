---
// src/pages/[slug].astro
// Dynamic route for CMS pages

import Layout from "../layouts/Layout.astro";
import WidgetPlacementZone from "@/components/WidgetPlacementZone.astro";
import { getPageRenderData, getLayoutData } from "../lib/api";
import { processShortcodes } from "../lib/shortcodes";
import { isStandaloneShortcodeContent } from "../lib/shortcode-content";
import {
  getRuntimeStorefrontUrl,
  setRuntimeImageCdnPolicy,
} from "@/lib/api/runtime-env";
import { getOptimizedImageUrl } from "@/lib/image-optimizer";
import { optimizeRichContentImages } from "@/lib/rich-content-media";
import { sanitizeHtml } from "@scalius/shared/html-sanitize";

const { slug } = Astro.params;

// === EARLY VALIDATION ===
// Return 404 immediately for invalid slugs WITHOUT making API calls.
// This prevents unnecessary API requests from reaching the backend.

// 1. No slug provided
if (!slug) {
  return new Response(null, { status: 404 });
}

// 2. Reject file extensions (these should be served from /public or other routes)
// Common extensions that might accidentally fall through to this catch-all route
const hasFileExtension = /\.[a-zA-Z0-9]{2,5}$/.test(slug);
if (hasFileExtension) {
  return new Response(null, { status: 404 });
}

// 3. Reject known non-page paths that might slip through routing
const invalidSlugs = [
  "api",
  "favicon",
  "_astro",
  "_worker",
  "assets",
  "images",
  "fonts",
  "static",
];
if (invalidSlugs.some((invalid) => slug.startsWith(invalid))) {
  return new Response(null, { status: 404 });
}

// 4. Validate slug format (only allow lowercase letters, numbers, hyphens)
// Most CMS systems use clean URL slugs - reject anything weird
const validSlugPattern = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
if (!validSlugPattern.test(slug)) {
  return new Response(null, { status: 404 });
}

// === NOW SAFE TO MAKE API CALL ===
// Parallel fetch: layout + page render data
const [layoutData, pageRenderData] = await Promise.all([
  getLayoutData(),
  getPageRenderData(slug),
]);
setRuntimeImageCdnPolicy(layoutData?.media);

const page = pageRenderData?.page ?? null;
if (!page) {
  return new Response(null, { status: 404 });
}
const pageWidgets = pageRenderData?.widgets ?? [];

const title = page.metaTitle || page.title;
const description = page.metaDescription || "";
const sanitizedPageContent = sanitizeHtml(page.content || "");
const isStandaloneShortcodePage =
  isStandaloneShortcodeContent(sanitizedPageContent);

let processedContent = sanitizedPageContent;
if (sanitizedPageContent) {
  try {
    processedContent = await processShortcodes(sanitizedPageContent);
  } catch (error: unknown) {
    console.error(`Error processing shortcodes for page "${slug}":`, error);
    processedContent = sanitizedPageContent;
  }
}
processedContent = optimizeRichContentImages(processedContent);

const hasProductShortcode = processedContent.includes(
  'class="product-shortcode-container"',
);

const featuredImage = page.featuredImage ?? null;
const featuredImageUrl = featuredImage?.url
  ? getOptimizedImageUrl(featuredImage.url, {
      width: 1280,
      height: 640,
      quality: 85,
      format: "auto",
      fit: "cover",
    })
  : "";
const featuredImageAlt =
  featuredImage?.altText || featuredImage?.filename || page.title;

// --- SEO: canonical URL for CMS pages (per OG-03, CAN-01) ---
const storefrontUrl = getRuntimeStorefrontUrl();
const canonicalUrl = `${storefrontUrl}/${slug}`;
const richContentClasses =
  "prose dark:prose-invert prose-lg prose-gray max-w-none w-full prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-primary hover:prose-a:text-primary/80 prose-img:rounded-xl";
---

<Layout
  title={title}
  description={description}
  hideHeader={page.hideHeader}
  hideFooter={page.hideFooter}
  layoutData={layoutData}
  canonicalUrl={canonicalUrl}
  ogImage={featuredImageUrl || undefined}
  ogType="website"
>
  <WidgetPlacementZone
    widgets={pageWidgets}
    scope="page"
    scopeId={page.id}
    placementSlot="top"
    priority
  />
  {
    isStandaloneShortcodePage ? (
      <>
        {featuredImageUrl && (
          <div class="mx-auto w-full max-w-7xl px-4 pt-6">
            <img
              src={featuredImageUrl}
              alt={featuredImageAlt}
              class="h-auto w-full rounded-lg object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        )}
        <WidgetPlacementZone
          widgets={pageWidgets}
          scope="page"
          scopeId={page.id}
          placementSlot="before_content"
        />
        <div class="w-full overflow-hidden" set:html={processedContent} />
        <WidgetPlacementZone
          widgets={pageWidgets}
          scope="page"
          scopeId={page.id}
          placementSlot="after_content"
        />
      </>
    ) : (
      <div class="w-full max-w-7xl mx-auto px-4 py-8">
        <div class="text-center mb-8">
          {!page.hideTitle && (
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3 tracking-tight">
              {page.title}
            </h1>
          )}
        </div>

        {featuredImageUrl && (
          <figure class="mb-8 overflow-hidden rounded-lg bg-gray-100">
            <img
              src={featuredImageUrl}
              alt={featuredImageAlt}
              class="h-auto w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </figure>
        )}

        <WidgetPlacementZone
          widgets={pageWidgets}
          scope="page"
          scopeId={page.id}
          placementSlot="before_content"
          itemClass="mb-8"
        />

        <div class="w-full">
          <div class={richContentClasses} set:html={processedContent} />
        </div>

        <WidgetPlacementZone
          widgets={pageWidgets}
          scope="page"
          scopeId={page.id}
          placementSlot="after_content"
          itemClass="mt-8"
        />

        <div class="text-center mt-10 pt-6 border-t border-gray-100">
          <a
            href="/"
            class="inline-flex items-center px-4 py-2 text-gray-500 hover:text-gray-900 transition-colors text-sm font-medium"
          >
            <svg
              class="w-4 h-4 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 19l-7-7m0 0l7-7m-7 7h18"
              />
            </svg>
            Back to Home
          </a>
        </div>
      </div>
    )
  }
  <WidgetPlacementZone
    widgets={pageWidgets}
    scope="page"
    scopeId={page.id}
    placementSlot="bottom"
  />
  {
    hasProductShortcode && (
      <script>import "../scripts/hydrateProductShortcodes.ts";</script>
    )
  }
</Layout>
