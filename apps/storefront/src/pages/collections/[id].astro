---
import Layout from "@/layouts/Layout.astro";
import ProductCard from "@/components/cards/ProductCard.astro";
import WidgetPlacementZone from "@/components/WidgetPlacementZone.astro";
import {
  getCollectionById,
  type ApiWidget,
  type CollectionWithProducts,
} from "@/lib/api";
import { getActiveWidgetsForScope } from "@/lib/api/widgets";
import { getRuntimeStorefrontUrl } from "@/lib/api/runtime-env";
import { loadPageWithLayout } from "@/lib/page-data";
import { getProductImageUrl } from "@/lib/product-media";
import { serializeJsonForInlineScript } from "@/lib/safe-json";
import { DEFAULT_CURRENCY } from "@scalius/shared/currency";
import { ArrowLeft, Tags } from "lucide-react";

const { id } = Astro.params;
if (!id) {
  return new Response(null, { status: 404 });
}

const { layoutData, pageData } = await loadPageWithLayout(async () => {
  const [collection, widgets] = await Promise.all([
    getCollectionById(id),
    getActiveWidgetsForScope("collection", id),
  ]);

  return {
    collection,
    widgets: widgets ?? [],
  };
});

const collection = pageData.collection as CollectionWithProducts | null;
if (!collection) {
  return new Response(null, { status: 404 });
}

const collectionWidgets = pageData.widgets as ApiWidget[];
const products = collection.products ?? [];
const categories = collection.categories ?? [];
const config = collection.config ?? {};
const title = config.title || collection.name;
const subtitle = config.subtitle || "";
const storefrontUrl = getRuntimeStorefrontUrl();
const collectionPath = `/collections/${encodeURIComponent(collection.id)}`;
const canonicalUrl = `${storefrontUrl}${collectionPath}`;
const currencySymbol = layoutData?.currency?.symbol ?? DEFAULT_CURRENCY.symbol;
const firstProductImage = products.find((product) => product.imageUrl)?.imageUrl ?? null;
const ogImageUrl = firstProductImage
  ? getProductImageUrl(firstProductImage, {
      width: 1200,
      height: 630,
      quality: 85,
      format: "auto",
      fit: "cover",
    })
  : undefined;

const collectionJsonLd = serializeJsonForInlineScript({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description: subtitle || `Browse ${collection.name}.`,
  url: canonicalUrl,
  numberOfItems: products.length,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: `${storefrontUrl}/`,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: collection.name,
        item: canonicalUrl,
      },
    ],
  },
});
---

<Layout
  title={title}
  description={subtitle || `Browse ${collection.name}.`}
  layoutData={layoutData}
  canonicalUrl={canonicalUrl}
  ogImage={ogImageUrl}
  ogType="website"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={collectionJsonLd} />
  </Fragment>

  <main class="min-h-screen bg-gray-50">
    <WidgetPlacementZone
      widgets={collectionWidgets}
      scope="collection"
      scopeId={collection.id}
      placementSlot="top"
      priority
    />

    <section class="bg-linear-to-b from-gray-50 to-white border-b border-gray-100">
      <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
        <nav class="mb-4 text-sm">
          <ol class="flex items-center gap-2">
            <li>
              <a href="/" class="inline-flex items-center gap-1.5 text-gray-500 hover:text-gray-900">
                <ArrowLeft className="h-4 w-4" />
                Home
              </a>
            </li>
            <li class="text-gray-300">/</li>
            <li>
              <span class="font-medium text-gray-900">{collection.name}</span>
            </li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="max-w-2xl space-y-2">
            <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
              {title}
            </h1>
            {subtitle && <p class="text-base text-gray-500 sm:text-lg">{subtitle}</p>}
            {
              categories.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-2">
                  {categories.map((category) => (
                    <a
                      href={`/categories/${category.slug}`}
                      class="rounded-full bg-muted px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-primary"
                    >
                      {category.name}
                    </a>
                  ))}
                </div>
              )
            }
          </div>

          <div class="flex items-center gap-2 rounded-lg border border-gray-100 bg-white px-3 py-1.5 shadow-sm">
            <Tags className="h-4 w-4 text-gray-400" />
            <span class="text-sm font-medium text-gray-900">
              {products.length} products
            </span>
          </div>
        </div>
      </div>
    </section>

    <WidgetPlacementZone
      widgets={collectionWidgets}
      scope="collection"
      scopeId={collection.id}
      placementSlot="before_content"
      itemClass="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3"
    />

    <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      {
        products.length > 0 ? (
          <div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
            {products.map((product) => (
              <ProductCard product={product} currencySymbol={currencySymbol} />
            ))}
          </div>
        ) : (
          <div class="rounded-lg border border-dashed border-gray-200 bg-white px-6 py-12 text-center">
            <p class="text-sm font-medium text-gray-900">No products in this collection yet.</p>
          </div>
        )
      }
    </section>

    <WidgetPlacementZone
      widgets={collectionWidgets}
      scope="collection"
      scopeId={collection.id}
      placementSlot="after_content"
      itemClass="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3"
    />

    <WidgetPlacementZone
      widgets={collectionWidgets}
      scope="collection"
      scopeId={collection.id}
      placementSlot="bottom"
      itemClass="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3"
    />
  </main>
</Layout>
