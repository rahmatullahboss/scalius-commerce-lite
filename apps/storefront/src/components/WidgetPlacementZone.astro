---
import type { ApiWidget } from "@/lib/api";
import WidgetBlock from "@/components/WidgetBlock.astro";
import { getWidgetsForZone, type WidgetPlacementZone } from "@/lib/widget-placements";

interface Props extends Omit<WidgetPlacementZone, "slot"> {
  widgets: ApiWidget[];
  placementSlot: WidgetPlacementZone["slot"];
  class?: string;
  itemClass?: string;
  priority?: boolean;
}

const {
  widgets,
  placementSlot,
  class: className = "",
  itemClass = "",
  priority = false,
  ...zone
} = Astro.props;
const zoneWidgets = getWidgetsForZone(widgets, {
  ...zone,
  slot: placementSlot,
});
---

{
  zoneWidgets.length > 0 && (
    <div class:list={["widget-placement-zone", className]}>
      {zoneWidgets.map((widget, index) => (
        <WidgetBlock
          widget={widget}
          class={itemClass}
          priority={priority && index === 0}
        />
      ))}
    </div>
  )
}
