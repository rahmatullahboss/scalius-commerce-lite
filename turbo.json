{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    ".env*",
    "apps/api/.dev.vars",
    "apps/api/.env*",
    "apps/admin-v2/.dev.vars",
    "apps/admin-v2/.env*",
    "apps/storefront/.dev.vars",
    "apps/storefront/.env*",
    "pnpm-lock.yaml",
    "eslint.config.js",
    "scripts/copy-flags.mjs"
  ],
  "globalEnv": [
    "PUBLIC_API_URL",
    "PUBLIC_API_BASE_URL",
    "PUBLIC_STOREFRONT_URL",
    "STOREFRONT_URL",
    "CDN_DOMAIN_URL",
    "R2_PUBLIC_URL",
    "BETTER_AUTH_URL",
    "VITE_FIREBASE_API_KEY",
    "VITE_FIREBASE_AUTH_DOMAIN",
    "VITE_FIREBASE_PROJECT_ID",
    "VITE_FIREBASE_STORAGE_BUCKET",
    "VITE_FIREBASE_MESSAGING_SENDER_ID",
    "VITE_FIREBASE_APP_ID",
    "VITE_FIREBASE_MEASUREMENT_ID",
    "VITE_VAPID_FIREBASE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "scripts/**",
        "package.json",
        "tsconfig.json",
        "wrangler.jsonc",
        "wrangler.local.jsonc",
        "astro.config.mjs",
        "*.config.*",
        "!**/.DS_Store",
        "!src/config/build-id.ts"
      ],
      "outputs": [
        "dist/**",
        "!dist/**/.dev.vars",
        "!dist/**/.env",
        "!dist/**/.env.*",
        "!dist/**/*.vars",
        ".astro/**"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tsconfig.json",
        "*.config.*",
        "!**/.DS_Store",
        "!src/config/build-id.ts"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "eslint.config.js",
        "package.json",
        "tsconfig.json",
        "*.config.*",
        "!**/.DS_Store",
        "!src/config/build-id.ts"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "db:generate": { "cache": false },
    "db:migrate:local": { "cache": false },
    "db:migrate:remote": { "cache": false }
  }
}
