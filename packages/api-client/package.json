{
  "name": "@scalius/api-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/generated/types.gen.ts",
    "./sdk": "./src/generated/sdk.gen.ts",
    "./client": "./src/generated/client.gen.ts",
    "./factory": "./src/client-factory.ts"
  },
  "scripts": {
    "generate": "node --import ./scripts/register-cloudflare-spec-loader.mjs --import tsx scripts/generate-spec.ts && openapi-ts",
    "generate:spec": "node --import ./scripts/register-cloudflare-spec-loader.mjs --import tsx scripts/generate-spec.ts",
    "lint": "eslint src/ scripts/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@scalius/tsconfig": "workspace:*",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
