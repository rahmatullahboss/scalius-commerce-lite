{
  "name": "scalius-commerce",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:all": "pnpm dev",
    "dev:api": "bash scripts/dev.sh --filter=@scalius/api",
    "dev:admin": "bash scripts/dev.sh --filter=@scalius/admin-v2 --filter=@scalius/api",
    "dev:storefront": "bash scripts/dev.sh --filter=@scalius/storefront --filter=@scalius/api",
    "prebuild": "node scripts/copy-flags.mjs",
    "build": "turbo run build",
    "deploy": "node scripts/deploy.mjs",
    "deploy:api": "node scripts/deploy.mjs --only api",
    "deploy:admin": "node scripts/deploy.mjs --only admin",
    "deploy:storefront": "node scripts/deploy.mjs --only storefront",
    "typecheck": "turbo run typecheck",
    "dev:setup": "node scripts/dev-setup.mjs",
    "dev:reset": "node scripts/dev-reset.mjs",
    "dev:admin:create": "node scripts/dev-admin.mjs create",
    "dev:admin:reset": "node scripts/dev-admin.mjs reset",
    "dev:admin:status": "node scripts/dev-admin.mjs status",
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "dev:doctor:api": "node scripts/dev-doctor.mjs --profile api --require-running",
    "dev:doctor:admin": "node scripts/dev-doctor.mjs --profile admin --require-running",
    "dev:doctor:storefront": "node scripts/dev-doctor.mjs --profile storefront --require-running",
    "dev:doctor:all": "node scripts/dev-doctor.mjs --profile all --require-running",
    "db:generate": "turbo run db:generate --filter=@scalius/api",
    "db:migrate:local": "turbo run db:migrate:local --filter=@scalius/api",
    "db:migrate:remote": "turbo run db:migrate:remote --filter=@scalius/api",
    "db:studio": "drizzle-kit studio --config packages/database/drizzle.config.ts",
    "check:env": "node scripts/check-worker-env.mjs",
    "check:isolation": "node scripts/check-project-isolation.mjs",
    "check:dist-secrets": "node scripts/clean-dist-env-files.mjs --check",
    "generate:sdk": "turbo run generate --filter=@scalius/api-client",
    "lint": "turbo run lint --filter=!@scalius/tsconfig",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@scalius/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "4.1.8",
    "country-flag-icons": "1.6.17",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "turbo": "^2.9.18",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.6.0"
}
